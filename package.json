{
  "name": "survivor",
  "version": "0.1.0",
  "description": "網頁版生存遊戲",
  "scripts": {
    "dev": "npx serve .",
    "start": "npx serve .",
    "test": "vitest run",
    "test:watch": "vitest",
    "angles": "node -e \"const c=JSON.parse(require('fs').readFileSync('./config/angles.json','utf8'));console.log('↑上='+c.directions.up.angle+'°  ←左='+c.directions.left.angle+'°  ↓下='+c.directions.down.angle+'°  →右='+c.directions.right.angle+'°  預設='+c.defaultAngle+'°')\"",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "typecheck:watch": "tsc --noEmit -p jsconfig.json --watch"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com-chiisen:chiisen/survivor.js.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@rolldown/binding-win32-x64-msvc": "^1.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  }
}
