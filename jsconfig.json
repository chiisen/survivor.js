{
    "compilerOptions": {
        "checkJs": false,
        "allowJs": true,
        "noEmit": true,
        "target": "ES2022",
        "module": "ES2022",
        "moduleResolution": "bundler",
        "strict": false,
        "lib": ["ES2022", "DOM"]
    },
    "include": ["js/**/*.js", "tests/**/*.js"],
    "exclude": ["node_modules"]
}